# Copy this to .env on the server (NEVER commit the real .env).
# server.js reads these at startup.

# The Google Apps Script Web App URL. Kept server-side so it never ships to clients.
SHEET_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Optional: only accept POSTs whose Origin matches this. Defense-in-depth against
# random scripts hammering /api/submit from other origins.
ALLOWED_ORIGIN=https://form.lunarstrategy.com

# Port the Node proxy listens on (nginx reverse-proxies /api/ here).
PORT=3100
