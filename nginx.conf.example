# /etc/nginx/sites-available/founder-form
# Symlink into sites-enabled and reload nginx.

server {
    listen 80;
    listen [::]:80;
    server_name apply.yourdomain.com;

    # certbot will rewrite this to a 301 once TLS is set up.
    root /var/www/founder-form;
    index index.html;

    # Binary assets that don't change between deploys — long cache.
    location ~* \.(ttf|woff2?|mp4|webm|mov|png|jpg|jpeg|ico)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # HTML/CSS/JS — must revalidate so updates take effect immediately.
    location / {
        try_files $uri $uri/ =404;
        add_header Cache-Control "no-cache, must-revalidate";
    }

    # Don't serve dotfiles.
    location ~ /\. { deny all; }

    # Sensible defaults.
    server_tokens off;
    gzip on;
    gzip_types text/plain text/css application/javascript image/svg+xml;
    gzip_min_length 1024;
}
